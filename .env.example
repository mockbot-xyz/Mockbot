# ANSV Bot Environment Configuration
# Copy this file to .env to use environment variables with docker-compose

# Web configuration
WEB_PORT=5001
WEB_ENABLED=true

# TTS configuration
TTS_ENABLED=true

# Application options
# Use true/false for boolean values
LOG_LEVEL=INFO
REBUILD_CACHE=false
DEV_MODE=false

# Twitch OAuth Configuration
# Register your app at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_REDIRECT_URI=http://localhost:5001/auth/twitch/callback

# Optional: override other settings (these take precedence over settings.conf)
# TWITCH_TOKEN=your_token_here
# CHANNEL_LIST=channel1,channel2