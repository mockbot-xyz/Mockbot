# ANSV Bot Environment Configuration
# Copy this file to .env to use environment variables with docker-compose

# Web configuration
WEB_PORT=5001
WEB_ENABLED=true

# TTS configuration
TTS_ENABLED=true

# Application options
# Use true/false for boolean values
LOG_LEVEL=INFO
REBUILD_CACHE=false
DEV_MODE=false

# Twitch OAuth Configuration
# Register your app at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_REDIRECT_URI=http://localhost:5001/auth/twitch/callback

# Stripe Payment Configuration
# Create account at: https://dashboard.stripe.com/register
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Price ID for $2/month Premium subscription (create in Stripe Dashboard)
STRIPE_PREMIUM_PRICE_ID=price_your_price_id_here

# Optional: override other settings (these take precedence over settings.conf)
# TWITCH_TOKEN=your_token_here
# CHANNEL_LIST=channel1,channel2